# Spring
SPRING_PROFILES_ACTIVE=dev
API_PORT=8080

# Runner
RUNNER_INTERNAL_TOKEN=dev-internal-token
RUNNER_REDIS_STREAM=eval.run.requested
RUNNER_REDIS_GROUP=vfqc-runner

# PostgreSQL
POSTGRES_DB=vfqc_dev
POSTGRES_USER=vfqc
POSTGRES_PASSWORD=vfqc
POSTGRES_PORT=5432

# Database (used directly in Spring if not using docker-compose)
DB_URL=jdbc:postgresql://localhost:5432/vfqc_dev
DB_USERNAME=vfqc
DB_PASSWORD=vfqc
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=1

# Redis
REDIS_PASSWORD=
REDIS_PORT=6379

# Security
JWT_SECRET_KEY=change-me-to-a-long-random-secret-with-at-least-32-chars
VAT_SECRET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ENCRYPTION_SALT=

# Admin seed
VFQC_ADMIN_EMAIL=admin@vfqc.local
VFQC_ADMIN_PASSWORD=
VFQC_ADMIN_DISPLAY_NAME=VFQC Administrator

# URLs
# Docker Compose serves the client through Nginx on CLIENT_PORT.
# The client uses same-origin /api/* and Nginx forwards it to api:8080.
WEB_BASE_URL=http://localhost:3000
SERVER_BASE_URL=http://localhost:8080
VITE_API_URL=http://localhost:8080/api/v1
CLIENT_PORT=3000

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=8192

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=512

# OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Mail
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@localhost
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false

# Avatar
DEFAULT_AVATAR_URL=https://static.vecteezy.com/system/resources/previews/009/734/564/original/default-avatar-profile-icon-of-social-media-user-vector.jpg

# Java
JAVA_TOOL_OPTIONS=-Dfile.encoding=UTF-8 -XX:MaxRAMPercentage=75.0 -XX:InitialRAMPercentage=25.0 -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError
